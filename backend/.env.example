PORT=5000
MONGODB_URI=mongodb://localhost:27017/tin_tuc_247
CLIENT_URL=http://localhost:5173
AUTO_SYNC_ON_START=true

# News sync
SYNC_INTERVAL_MINUTES=30
MAX_ITEMS_PER_FEED=25
FEED_TIMEOUT_MS=10000
FEED_RETRIES=2
SYNC_CONCURRENCY=1
RSS_DETAIL_PER_SOURCE=3

# AI assistant: hệ thống tự chạy local fallback nếu chưa có key cloud.
AI_PROVIDERS=openai,gemini,groq,ollama,local
AI_TIMEOUT_MS=18000
AI_CONTEXT_ARTICLES=8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Football widget: có key thì dùng live API, không có key vẫn dùng TheSportsDB public fallback + tin bóng đá.
FOOTBALL_PROVIDER=auto
FOOTBALL_TIMEZONE=Asia/Ho_Chi_Minh
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io
FOOTBALL_DATA_API_KEY=
THESPORTSDB_API_KEY=
THESPORTSDB_DISABLE_PUBLIC=false
SCOREBAT_API_TOKEN=
FOOTBALL_SYNC_INTERVAL_MINUTES=15
FOOTBALL_LAZY_SYNC_COOLDOWN_MS=300000
FOOTBALL_FALLBACK_TO_NEWS=true

# Rice price widget
RICE_PRICE_SYNC_INTERVAL_MINUTES=60
RICE_PRICE_TIMEOUT_MS=12000
# Display limits
MAX_LATEST_DISPLAY_ARTICLES=4000
MAX_ARTICLES_PER_PAGE=100
